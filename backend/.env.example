# ============================================================================
# Configurações do backend
# ============================================================================
# Copie este arquivo para `.env` e preencha com seus valores reais.
# NUNCA comite o arquivo `.env` (já está no .gitignore).
# ============================================================================

# Supabase ------------------------------------------------------------------
# URL do projeto (em Project Settings → API → Project URL)
SUPABASE_URL=https://seu-projeto.supabase.co

# Service role key (em Project Settings → API → Project API keys → service_role)
# IMPORTANTE: bypassa RLS — NUNCA exponha no frontend
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# CORS ----------------------------------------------------------------------
# Origens permitidas para o frontend, separadas por vírgula
# Em desenvolvimento: http://localhost:3000
# Em produção: a URL do frontend no Vercel
CORS_ORIGINS=http://localhost:3000,https://seu-frontend.vercel.app

# App -----------------------------------------------------------------------
APP_NAME=API Monitoramento UNIVESP
APP_VERSION=1.0.0
DEBUG=false
