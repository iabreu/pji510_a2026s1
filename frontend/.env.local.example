# ============================================================================
# Configurações do frontend
# ============================================================================
# Copie este arquivo para `.env.local` e preencha com seus valores reais.
# ============================================================================

# Supabase ------------------------------------------------------------------
# URL do projeto (Project Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co

# anon (public) key — pode aparecer no client. RLS protege os dados.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Backend FastAPI -----------------------------------------------------------
# Em desenvolvimento: http://localhost:8000
# Em produção: a URL do backend no Vercel
NEXT_PUBLIC_API_URL=http://localhost:8000
